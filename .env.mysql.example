# Copy these lines into .env when MariaDB/MySQL credentials are ready:
#
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=menkem_tms
# DB_USERNAME=your_user
# DB_PASSWORD=your_password
#
# Then run:
#   mariadb -u your_user -p -e "CREATE DATABASE menkem_tms CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;"
#   php artisan migrate:fresh --seed
